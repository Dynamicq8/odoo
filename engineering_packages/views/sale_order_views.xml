<odoo>
    <record id="view_order_form_inherit_engineering_package" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.engineering.package</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <!-- Hidden field (no select UI) -->
                <field name="engineering_package_id" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
