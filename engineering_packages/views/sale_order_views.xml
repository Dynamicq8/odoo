<odoo>
    <record id="view_order_form_inherit_engineering_package" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.engineering.package</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            
            <!-- This targets the "نوع الخدمة" field and puts the package exactly below it -->
            <xpath expr="//field[@name='service_type']" position="after">
                <field name="engineering_package_id" 
                       options="{'no_create': True, 'no_open': True}"
                       placeholder="اختر باقة هندسية..."
                       domain="[
                           ('building_type', 'in', [building_type, 'all']),
                           ('service_type', 'in', [service_type, 'all'])
                       ]"/>
            </xpath>

        </field>
    </record>
</odoo>