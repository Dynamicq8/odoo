<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_engineering" model="ir.ui.view">
        <field name="name">crm.lead.form.engineering</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="before">
                <separator string="تفاصيل العقار والخدمة"/>
                <group>
                    <group>
                        <field name="building_type" widget="radio" options="{'horizontal': true}"/>
                        <field name="service_type" widget="radio" options="{'horizontal': true}"/>
                    </group>
                    <group>
                        <!-- The 'governorate' field has been removed as requested. -->
                        <!-- The 'region' field now stands alone, directly providing the full list of areas with governorate separators. -->
                        
                        <!-- NEW ODOO 17 SYNTAX HERE -->
                        <field name="region" 
                               required="True" 
                               placeholder="اختر المنطقة"/>
                        
                        <field name="area"/>
                        <field name="block_no"/>
                        <field name="street_no"/>
                        <field name="plot_no"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
