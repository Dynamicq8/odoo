<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form_engineering" model="ir.ui.view">
        <field name="name">sale.order.form.engineering</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <!-- ... other groups ... -->
                <group string="تفاصيل الموقع (Location Details)">
                    <field name="governorate" 
                           options="{'no_create': True, 'no_edit': True}"/>
                    
                    <!-- Odoo 17 Compliant Syntax -->
                    <field name="region" 
                           invisible="not region_is_visible" 
                           required="region_is_required" 
                           options="{'no_create': True, 'no_edit': True}"/>
                    
                    <field name="region_is_visible" invisible="1"/>
                    <field name="region_is_required" invisible="1"/>

                    <field name="area"/>
                    <field name="block_no"/>
                    <field name="street_no"/>
                    <field name="plot_no"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
