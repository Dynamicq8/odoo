<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form_engineering" model="ir.ui.view">
        <field name="name">sale.order.form.engineering</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                
                <!-- Project Details Section -->
                <group string="بيانات المشروع (Project Details)">
                    <field name="building_type"/>
                    <field name="service_type"/>
                </group>

                <!-- Location Details Section -->
                <group string="تفاصيل الموقع (Location Details)">
                    
                    <!-- Governorate field -->
                    <field name="governorate" placeholder="اختر المحافظة" />
<field name="region" invisible="not governorate" required="governorate" placeholder="اختر المنطقة" />
                    
                    <field name="area"/>
                    <field name="block_no"/>
                    <field name="street_no"/>
                    <field name="plot_no"/>
                    
                </group>

            </xpath>
        </field>
    </record>
</odoo>
