<odoo>
    <record id="sign_template_view_form_inherit_project_doc_gen" model="ir.ui.view">
        <field name="name">sign.template.form.inherit.project.doc.gen</field>
        <field name="model">sign.template</field>
        <field name="inherit_id" ref="sign.sign_template_view_form"/>
        <field name="arch" type="xml">
            <field name="responsible_id" position="after">
                <field name="is_project_document" />
                <field name="building_type" attrs="{'invisible': [('is_project_document', '=', False)]}"/>
            </field>
        </field>
    </record>
</odoo>
