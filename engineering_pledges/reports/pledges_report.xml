<odoo>

    <record id="action_report_unified_pledges" model="ir.actions.report">
        <field name="name">Municipality Pledges</field>
        <field name="model">project.task</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">engineering_pledges.report_unified_pledges_template</field>
        <field name="report_file">engineering_pledges.report_unified_pledges_template</field>
        <field name="print_report_name">'Pledges - %s' % (object.project_id.name)</field>
    </record>

    <template id="report_unified_pledges_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <t t-foreach="doc.pledge_ids" t-as="pledge">
                    <t t-call="web.basic_layout">

                        <div class="page" style="direction: rtl; text-align: right; font-family: Arial, sans-serif;">
                            <div t-raw="pledge.generated_html"/>
                        </div>

                    </t>
                </t>

            </t>
        </t>
    </template>

</odoo>
