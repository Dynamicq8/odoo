<odoo>
    <record id="edit_task_form_inherit_pledges" model="ir.ui.view">
        <field name="name">project.task.form.inherit.pledges</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="stage_sequence" invisible="1"/>
            </xpath>
            
            <xpath expr="//notebook" position="inside">
                <page string="تعهدات البلدية (Pledges)" name="municipality_pledges" invisible="stage_sequence != 2">
                    
                    <div class="mb-3">
                        <button name="action_load_required_pledges" 
                                string="تحميل التعهدات (Load Pledges)" 
                                type="object" 
                                class="btn-secondary" icon="fa-download"/>
                                
                        <!-- NEW BUTTON TO GENERATE PDF -->
                        <button name="action_generate_pledges_pdf" 
                                string="طباعة التعهدات (Print Pledges PDF)" 
                                type="object" 
                                class="btn-primary ms-2" icon="fa-print"
                                invisible="not pledge_ids"/>
                    </div>
                    
                    <field name="pledge_ids">
                        <tree editable="bottom" decoration-success="is_completed==True" decoration-danger="is_completed==False">
                            <field name="template_id" options="{'no_create': True}"/>
                            <field name="is_completed" widget="boolean_toggle"/>
                        </tree>
                    </field>

                </page>
            </xpath>

        </field>
    </record>
</odoo>
